<%layout("/layouts/boilerplate")%>
<% if(typeof activeCategory === 'undefined'){activeCategory = "";} %>
    
<style>
    #filters{
        display:flex;
        flex-wrap:nowwrap;
        overflow-x:auto;
        align-items:center;
        padding:0.5rem 1.5rem;
        position:sticky;
        top:4.5rem;
        z-index:99;
        background-color: rgba(255,255,255,0.95);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid #ebebeb;
    }

    #filters::-webkit-scrollbar{
        display:none;
    }

    .filter-link{
        text-decoration: none;
        text-align:center;
        color: inherit;
        opacity:0.8;
        margin-right:2rem;
        margin-top:2rem;
        transition:opacity 0.2s;
    }

    .filter-link:hover,
    .filter-link.active-filter {
        opacity:1;
        color:#222222;
        border-bottom:2px solid #222222;
    }

    .filters-title {
        display: flex;
        align-items: center;
        margin-right: 2.5rem; 
        padding-bottom: 2px;  
        border-right: 2px solid #e1e1e1; 
        padding-right: 1.5rem; 
    }

    .filters-title span {
        font-weight: 700;  
        color: #FF0000;  
        font-size: 0.95rem;  
        font-family: sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .tax-info {
        display:none;
    }

    .tax-toggle{
        border:1px solid black;
        border-radius:1rem;
        height:3.25rem;
        padding:1rem;
        margin-left:3rem;
        display:flex;
        align-items:center;
    }

</style>

<div id="filters">

    <div class="filters-title">
        <span>Categories</span>
    </div>
    
    <a href="/listings?category=Trending" class="filter-link <%= activeCategory === 'Trending' ? 'active-filter' : '' %>">
        <div class="filter">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </div>
    </a>

    <a href="/listings?category=Rooms" class="filter-link <%= activeCategory === 'Rooms' ? 'active-filter' : '' %>">
        <div class="filter">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </div>
    </a>

    <a href="/listings?category=Iconic Cities" class="filter-link <%= activeCategory === 'Iconic Cities' ? 'active-filter' : '' %>">
        <div class="filter">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic Cities</p>
        </div>
    </a>

    <a href="/listings?category=Mountains" class="filter-link <%= activeCategory === 'Mountains' ? 'active-filter' : '' %>">
        <div class="filter">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </div>
    </a>

    <a href="/listings?category=Castles" class="filter-link <%= activeCategory === 'Castles' ? 'active-filter' : '' %>">
        <div class="filter">
            <div><i class="fa-solid fa-fort-awesome"></i></div>
            <p>Castles</p>
        </div>
    </a>

    <a href="/listings?category=Amazing Pools" class="filter-link <%= activeCategory === 'Amazing Pools' ? 'active-filter' : '' %>">
        <div class="filter">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
        </div>
    </a>

    <a href="/listings?category=Camping" class="filter-link <%= activeCategory === 'Camping' ? 'active-filter' : '' %>">
        <div class="filter">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Camping</p>
        </div>
    </a>

    <a href="/listings?category=Farms" class="filter-link <%= activeCategory === 'Farms' ? 'active-filter' : '' %>">
        <div class="filter">
            <div><i class="fa-solid fa-tractor"></i></div>
            <p>Farms</p>
        </div>
    </a>

    <a href="/listings?category=Arctic" class="filter-link <%= activeCategory === 'Arctic' ? 'active-filter' : '' %>">
        <div class="filter">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </div>
    </a>

    <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display Taxes</label>
        </div>
    </div>

</div>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <%for(let listing of allListings){%>
        <a href="/listings/<%= listing._id %>" class="listing-link">
<div class="card col listing-card" >
  <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height:20rem">
  <div class="card-img-overlay">Heaven</div>
  <div class="card-body">
    <p class="card-text">
       <b> <%=listing.title%></b> <br>
        &#8377;<%=listing.price.toLocaleString("en-IN")%> /night
        <i class="tax-info"> &nbsp; &nbsp;+ 18% GST </i>
    </p>
  </div>
</div>
        </a>
<%}%>
</div>

<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click",()=>{
        let taxInfo = document.getElementsByClassName("tax-info");
        for(info of taxInfo){
           if(info.style.display != "inline"){
             info.style.display= "inline";
           }
           else{
            info.style.display = "none";
           }
        }
    });
</script>




