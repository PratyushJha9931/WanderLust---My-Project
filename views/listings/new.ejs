
<%layout("/layouts/boilerplate")%>
<div class="row mt-3">
    <div class="col-8 offset-2">
        <br><br>
    <h3>Create a New Listing</h3>
    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
            <lable for="title"class="form-lable">Title</lable>
        <input name="listing[title]" placeholder="Add a catchy Title" type="text" class="form-control" required>
        <div class="valid-feedback">Title Looks Good!</div>
        </div>
        
        <div class="mb-3">
            <lable for="description"class="form-lable">Description</lable>
            <textarea name="listing[description]" class="form-control" type="text" required></textarea>
            <div class="invalid-feedback">Please enter a description</div>
        </div>
        
        <div class="mb-3">
            <lable for="image" class="form-lable">Upload Image</lable>
            <input name="listing[image]" type="file" class="form-control">
            required
        </div>
        
        <div class="row">
            <div class="mb-3 col-md-4">
            <lable for="price"class="form-lable">Price</lable>
            <input name="listing[price]" placeholder="enter price"  class="form-control" required>
            <div class="invalid-feedback">Price should be valid</div>
        </div>
        
        <div class="mb-3 col-md-8">
            <lable for="country"class="form-lable">Country</lable>
            <input name="listing[country]" placeholder="India"type="text" class="form-control" required>
            <div class="invalid-feedback">Country is required</div>
        </div>
        </div>
        
        
        <div class="mb-3">
            <lable for="location"class="form-lable">Location</lable>
            <input name="listing[location]" placeholder="Jaipur,Patna,etc.."type="text" required>
            <div class="invalid-feedback">Please enter the location</div>
        </div>
        
        <div class="mb-3">
            <label for="category" class="form-label">Category</label>
            <select name="listing[category]" id="category" class="form-select" required>
                <option value="" disabled selected>Choose a category...</option>
                <option value="Trending">Trending</option>
                <option value="Rooms">Rooms</option>
                <option value="Iconic Cities">Iconic Cities</option>
                <option value="Mountains">Mountains</option>
                <option value="Castles">Castles</option>
                <option value="Amazing Pools">Amazing Pools</option>
                <option value="Camping">Camping</option>
                <option value="Farms">Farms</option>
                <option value="Arctic">Arctic</option>
            </select>
            <div class="invalid-feedback">Please select a valid category</div>
        </div>

        <button class="btn btn-dark add-btn mt-3">Add</button>

    </form>
    </div>
    </div>
